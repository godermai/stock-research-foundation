# Tushare Pro API token (required for primary data source)
TUSHARE_TOKEN=your_tushare_pro_token_here

# BaoStock (no token needed, free)
# BAOSTOCK_USER=
# BAOSTOCK_PASSWORD=

# CNINFO (no token for public queries, but rate-limited)
# CNINFO_COOKIE=

# Local storage paths
DATA_DIR=./data
DB_DIR=./db
DUCKDB_PATH=./db/market.duckdb
SQLITE_PATH=./db/state.sqlite

# Sync schedule
SYNC_MARKET_DAILY_CRON=0 18 * * 1-5
SYNC_FINANCIALS_CRON=0 20 * * 1-5
SYNC_ANNOUNCEMENTS_CRON=0 10,14 * * 1-5

# MCP server
MCP_TRANSPORT=stdio
MCP_LOG_LEVEL=INFO
